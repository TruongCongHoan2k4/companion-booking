# Sao chép thành .env và chỉnh nếu cần.
#
# vite.config.js proxy: /api, /socket.io, /ws, /logout → host suy ra từ VITE_API_URL (mặc định port 3000).

# Base URL API (proxy Vite). Ví dụ backend tại cổng 3000:
VITE_API_URL=http://localhost:3000/api

# Socket.IO client:
# - Để trống: dùng window.location.origin (dev qua Vite + proxy /socket.io).
# - Hoặc http://localhost:3000 để nối thẳng backend (nhớ FRONTEND_URL trên backend khớp CORS).
VITE_SOCKET_URL=

# Cookie HttpOnly + CORS: biến FRONTEND_URL trên backend phải trùng origin app (vd. http://localhost:5173).
# Vite chỉ expose biến bắt đầu bằng VITE_*; cấu hình origin nằm ở backend/.env.

# Dự phòng (code tĩnh / tính năng chưa dùng)
VITE_USE_MOCK=false

# Cypress E2E (PowerShell: $env:CYPRESS_E2E_USER="..."; $env:CYPRESS_E2E_PASSWORD="..."; npm run cypress:run)
# CYPRESS_API_URL=http://localhost:3000/api
# CYPRESS_E2E_USER=
# CYPRESS_E2E_PASSWORD=
