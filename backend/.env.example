# Sao chép thành .env và điền giá trị thật. Không commit file .env.
#
# === Bắt buộc / thường dùng (được đọc trong mã nguồn) ===

# Cổng HTTP (server.js)
PORT=3000

# MongoDB — tên biến là MONGO_URI (không dùng MONGODB_URI).
# Giao dịch Mongoose (nạp ví / đặt lịch / hoàn cọc) cần replica set.
MONGO_URI=mongodb://127.0.0.1:27017/companion_db?replicaSet=rs0

# JWT đăng nhập (auth.service, verifyToken, Socket.IO handshake)
ACCESS_TOKEN_SECRET=thay_bang_chuoi_bi_mat_dai_ngau_nhien
ACCESS_TOKEN_EXPIRES=15m

NODE_ENV=development

# CORS + Socket.IO — phải trùng origin frontend (Vite mặc định http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Cloudinary — upload companion (identity/avatar/video). Thiếu → API upload trả 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — OTP quên mật khẩu. SMTP_HOST trống → OTP in ra console backend (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
OTP_EXPIRE_MINUTES=15

# === Dự phòng — CHƯA được import trong backend/src (giữ để tích hợp sau) ===
# Không cần điền để chạy smoke test các luồng hiện có.

REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES=7d

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL=http://localhost:5173/pages/user/wallet.html
MOMO_IPN_URL=http://localhost:3000/api/callback/momo
